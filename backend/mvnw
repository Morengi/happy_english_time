#!/bin/sh
#
# Maven Wrapper script
#
set -e

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD='java'
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

if [ ! -x "$JAVACMD" ] && ! command -v java > /dev/null 2>&1 ; then
  echo "Error: JAVA_HOME is not set and no 'java' command found."
  exit 1
fi

# Find the project base dir (parent of .mvn folder)
BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_JAR="$BASE_DIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$BASE_DIR/.mvn/wrapper/maven-wrapper.properties"

# Read distributionUrl
DISTRIBUTION_URL=$(grep distributionUrl "$WRAPPER_PROPERTIES" | cut -d= -f2-)

# Download wrapper jar if missing
if [ ! -f "$WRAPPER_JAR" ]; then
  WRAPPER_URL=$(grep wrapperUrl "$WRAPPER_PROPERTIES" | cut -d= -f2-)
  echo "Downloading Maven wrapper..."
  if command -v curl > /dev/null 2>&1; then
    curl -fsL -o "$WRAPPER_JAR" "$WRAPPER_URL"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL"
  else
    echo "Error: need curl or wget to download Maven wrapper."
    exit 1
  fi
fi

exec "$JAVACMD" \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$BASE_DIR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
