# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# Пароль PostgreSQL
DB_PASSWORD=сюда_сильный_пароль

# JWT секрет (минимум 32 случайных символа)
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=сюда_случайный_секрет_минимум_32_символа

# Порт для фронтенда (по умолчанию 80)
PORT=80
